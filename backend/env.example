# ─── REQUIRED ──────────────────────────────────────────────────────────────

# MongoDB connection string
# Option A - Local MongoDB:
MONGO_URI=mongodb://localhost:27017/rr_construction_cms
# Option B - MongoDB Atlas (cloud, free tier):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rr_construction_cms

# JWT secret — change this to any long random string in production
JWT_SECRET=rrconstruction_secret_2025
JWT_EXPIRE=7d

# ─── OPTIONAL ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Email (for contact/quotation notifications — optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
